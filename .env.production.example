APP_NAME="PicMe225"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://www.picme225.site
APP_PUBLIC_URL=https://www.picme225.site

LOG_CHANNEL=stack
LOG_LEVEL=error

# ===========================================================
# BASE DE DONNÉES — PostgreSQL (Production)
# ===========================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=picme225_prod
DB_USERNAME=picme225_user
DB_PASSWORD=VOTRE_MOT_DE_PASSE_SECURISE

# ===========================================================
# CACHE & SESSIONS
# ===========================================================
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================================
# MAIL
# ===========================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=noreply@picme225.site
MAIL_PASSWORD=VOTRE_MOT_DE_PASSE_MAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@picme225.site
MAIL_FROM_NAME="PicMe225"

# ===========================================================
# SMS / FIREBASE
# ===========================================================
FIREBASE_API_KEY=AIzaSyAwsy0qo-17ONTGZcWz5ptvE9rsF0w_4X4
FIREBASE_AUTH_DOMAIN=picme-driver.firebaseapp.com
FIREBASE_PROJECT_ID=picme-driver
FIREBASE_STORAGE_BUCKET=picme-driver.appspot.com
FIREBASE_MESSAGING_SENDER_ID=753575568169
FIREBASE_APP_ID=1:753575568169:web:3f8bf626edf28b669e4d38

# ===========================================================
# PAIEMENTS (CinetPay / MoMo)
