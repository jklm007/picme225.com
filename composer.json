{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "anlutro/l4-settings": "^1.4",
        "barryvdh/laravel-translation-manager": "^0.6.4",
        "beyondcode/laravel-websockets": "^1.14",
        "hesto/multi-auth": "^2.0",
        "kreait/firebase-php": "^6.1.0",
        "laravel/framework": "^10.0",
        "laravel/passport": "^12.3",
        "laravel/socialite": "^5.16",
        "laravel/ui": "^4.6",
        "lcobucci/jwt": "^4.0",
        "league/flysystem-aws-s3-v3": "^3.34",
        "predis/predis": "^3.4",
        "pusher/pusher-php-server": "^7.2",
        "spatie/laravel-translation-loader": "^2.8",
        "stripe/stripe-php": "^10.21.0",
        "symfony/polyfill-mbstring": "^1.31.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Database\\Seeders\\": "database/seeders/",
            "App\\": "app/"
        },
        "files": [
            "app/Helper/ControllerHelper.php",
            "app/Helper/ViewHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall",
            "php artisan optimize"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "php artisan optimize"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        },
        "audit": {
            "ignore": ["PKSA-t5xz-td8w-f35v", "PKSA-jsh4-f6tg-bwyq", "PKSA-4p7m-np8m-fq35", "PKSA-mnsd-qtjt-pgcq"],
            "block-insecure": false
        },
        "platform-check": false
    }
}
