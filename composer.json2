{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=7.4.0",
        "anlutro/l4-settings": "^0.4.9",
        "barryvdh/laravel-translation-manager": "^0.2.7",
        "hesto/multi-auth": "^1.0",
        "laravel/framework": "^6.0",
        "laravel/passport": "^8.0",
        "laravel/socialite": "^2.0",
        "mjaschen/phpgeo": "^1.3",
        "stripe/stripe-php": "^4.4",
        "turbo124/laravel-push-notification": "dev-laravel5",
        "tymon/jwt-auth": "^1.0",
        "lcobucci/jwt": "^4.0"
    },
    "require-dev": {
        "fzaninotto/faker": "dev-master",
        "mockery/mockery": "0.9.*",
        "phpunit/phpunit": "^7.5",
        "symfony/css-selector": "3.1.*",
        "symfony/dom-crawler": "3.1.*"
    },
    "autoload": {
        "classmap": [
            "database"
        ],
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helper/ControllerHelper.php",
            "app/Helper/ViewHelper.php"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall",
            "php artisan optimize"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "php artisan optimize"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        }
    }
}
